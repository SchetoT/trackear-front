---
const {
  title = 'TrackeAR | Seguimiento de envíos en Argentina',
  description = 'Seguimiento de envíos para empresas de paquetería y logística en Argentina.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/global.css" />
  </head>
  <body>
    <slot />
  </body>
</html>